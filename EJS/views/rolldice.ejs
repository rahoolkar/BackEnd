<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rolling the Dice</title>
</head>
<body>
    <h1>Dice number is <%= number %></h1>
    <!-- Conditional Statements -->
    <%if(number==6){%>
        <h2>Nice!!You can roll the dice again!</h2>
    <% } %>

    <!-- Loops -->
    <ul>
        <% for(let person of persons){ %>
            <li><b><%= person %></b></li>
        <% } %>
    </ul>
</body>
</html>