<%- include("includes/head.ejs") %>
<body>
    <h1>This page belongs to <%= data.name%></h1>
    <button>Follow</button>
    <button>Messege</button>
    <p><b>Followers : <%=data.followers%></b> <br> <b>Following : <%=data.following %></b></p>
    <% for(let post of data.posts){ %>
        <img src="<%= post.image %>" alt="some-image">
        <p><b>Likes : <%= post.likes %></b></p>
        <p><b>Comments : <%= post.comments %></b></p>
    <% } %>
   <script src="/app.js"></script>
</body>
</html>